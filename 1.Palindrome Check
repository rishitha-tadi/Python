string = input("Enter a string:")
left = 0
right = len(string)-1
isPalindrome = True
while left < right:
    if string[left] != string[right]:
        isPalindrome = False
        break
    left = left + 1
    right = right - 1
if isPalindrome:
    print("The string is a palindrome")
else:
    print("The string is not a palindrome")
